full_dot = '●'
empty_dot = '○'

def create_character(name, stgh, intl, char):

    if not isinstance(name, str):
        return "The character name should be a string"

    if name == "":
        return "The character should have a name"

    if len(name) > 10:
        return "The character name is too long"

    if " " in name:
        return "The character name should not contain spaces"

    if not isinstance(stgh, int) or not isinstance(intl, int) or not isinstance(char, int):
        return "All stats should be integers"

    if stgh < 1 or intl < 1 or char < 1:
        return "All stats should be no less than 1"

    if stgh > 4 or intl > 4 or char > 4:
        return "All stats should be no more than 4"

    if stgh + intl + char != 7:
        return "The character should start with 7 points"

    result = (
        name + "\n" +
        "STR " + full_dot * stgh + empty_dot * (10 - stgh) + "\n" +
        "INT " + full_dot * intl + empty_dot * (10 - intl) + "\n" +
        "CHA " + full_dot * char + empty_dot * (10 - char)
    )

    return result
print(create_character('Haseo',3,3,1))
